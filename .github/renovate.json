{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>Cramraika/.github"
  ],
  "packageRules": [
    {
      "description": "OSS: auto-merge ALL minor (non-major)",
      "matchUpdateTypes": [
        "minor"
      ],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": false
    }
  ]
}
